# Copy to .env and fill in. Never commit .env.

# --- Generator LLM ---
# The provider is chosen by THREE knobs together: base_url + api_key + the
# `models.llm.model` in config.yaml. base_url alone only switches between
# OpenAI-COMPATIBLE endpoints. Presets:
#
#   OpenAI   OPENAI_BASE_URL=            (blank — SDK default)   model: gpt-5.5
#   xAI Grok OPENAI_BASE_URL=https://api.x.ai/v1                 model: grok-...
#   Claude   OPENAI_BASE_URL=https://api.anthropic.com/v1/       model: claude-opus-4-8
#            ^ via Anthropic's OpenAI-compatibility endpoint (a shim: some params
#              ignored, no full tool-use / prompt-caching parity). Fine for plain
#              text generation. For full Claude features add a native anthropic
#              backend (models.llm.backend: anthropic) later.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- YouTube chat posting (Data API v3, OAuth2) ---
# Path to the OAuth client secrets JSON downloaded from Google Cloud Console.
YOUTUBE_CLIENT_SECRETS=
# Path where the cached OAuth token will be stored after first auth.
YOUTUBE_TOKEN_PATH=.youtube_token.json

# --- Optional: override config.yaml location ---
LINGUS_CONFIG=config.yaml
